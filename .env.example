# MVP app (separate Next.js app). Required on Vercel Production + Preview so "Try Demo"
# points at the real app — never localhost (visitors cannot reach your machine).
# Local `next dev`: omit this to default to http://localhost:3000
# Example production: https://your-mvp-app.vercel.app  (no trailing slash)
# NEXT_PUBLIC_MVP_URL=https://your-mvp-app.vercel.app

